# Copy this file to .env and fill in real values. Never commit .env.

FLASK_ENV=development
SECRET_KEY=change-me

# --- Database (Supabase Postgres, session pooler connection string) ---
DATABASE_URL=postgresql+psycopg2://postgres.your-project-ref:YOUR_DB_PASSWORD@aws-1-region.pooler.supabase.com:5432/postgres?sslmode=require

# --- JWT ---
JWT_SECRET_KEY=generate-a-long-random-value

# --- Supabase (Storage) ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=jobbridge-files

# --- Mail (Brevo transactional email API — https://app.brevo.com/settings/keys/api) ---
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=your-verified-sender@example.com
BREVO_SENDER_NAME=JobBridge PESO Pila

# --- CORS ---
CORS_ORIGINS=http://localhost:5173

# --- AI services (optional — leave blank to run in stub/mock mode) ---
# Place downloaded service-account JSONs under backend/credentials/ (that whole
# directory is git-ignored — see .gitignore). Vision and Dialogflow are commonly
# two separate GCP projects/service accounts, so each gets its own credential path
# rather than sharing one — do not point both at the same file unless that service
# account has been explicitly granted IAM roles on both projects.
#
# Vision also requires billing enabled on its project, or calls fail with a billing
# error (SERVICE_DISABLED/billing errors both fall back to mock output automatically).
# Dialogflow also requires the Dialogflow API to be explicitly enabled on its project
# (APIs & Services > Library > Dialogflow API > Enable), separate from IAM permissions.
GOOGLE_APPLICATION_CREDENTIALS=credentials/google-vision-service-account.json
DIALOGFLOW_PROJECT_ID=
DIALOGFLOW_CREDENTIALS_PATH=credentials/dialogflow-service-account.json

# --- Admin seed (used only by seed.py) ---
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=change-me

RATELIMIT_STORAGE_URI=memory://
MAINTENANCE_MODE=false
