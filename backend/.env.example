# Copy this file to .env and fill in real values. Never commit .env.

FLASK_ENV=development
SECRET_KEY=change-me

# --- Database (Supabase Postgres, session pooler connection string) ---
DATABASE_URL=postgresql+psycopg2://postgres.your-project-ref:YOUR_DB_PASSWORD@aws-1-region.pooler.supabase.com:5432/postgres?sslmode=require

# --- JWT ---
JWT_SECRET_KEY=generate-a-long-random-value

# --- Supabase (Storage) ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=jobbridge-files

# --- Mail (Gmail SMTP) ---
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-gmail-address@gmail.com
MAIL_PASSWORD=your-gmail-app-password

# --- CORS ---
CORS_ORIGINS=http://localhost:5173

# --- AI services (optional — leave blank to run in stub/mock mode) ---
# Place the downloaded service-account JSON under backend/credentials/ (that whole
# directory is git-ignored — see .gitignore) and point this at it. The GCP project
# must also have billing enabled, or Vision API calls fail with a billing error and
# ocr_service.py falls back to mock output automatically.
GOOGLE_APPLICATION_CREDENTIALS=credentials/google-vision-service-account.json
DIALOGFLOW_PROJECT_ID=

# --- Admin seed (used only by seed.py) ---
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=change-me

RATELIMIT_STORAGE_URI=memory://
MAINTENANCE_MODE=false
